# WhatsApp Cloud API
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_access_token
WA_VERIFY_TOKEN=your_webhook_verify_token

# AI — Gemini (set to 'mock' to use Groq instead)
GEMINI_API_KEY=mock

# AI — Groq (LLaMA 3.3 70B chat + Whisper transcription)
GROQ_API_KEY=your_groq_key

# Supabase (omit to use local sql.js)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your_service_role_key

# Boxy delivery (optional)
# BOXY_API_URL=https://api.tryboxy.com/v1
# BOXY_API_KEY=your_boxy_key
# BOXY_API_SECRET=your_boxy_secret

# App
PORT=3002
MERCHANT_PHONE=964770000001
