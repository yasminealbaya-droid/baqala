# WhatsApp Cloud API (free for customer-initiated)
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_access_token
WA_VERIFY_TOKEN=your_webhook_verify_token

# Google Gemini (free: 250 RPD, 10 RPM)
GEMINI_API_KEY=your_gemini_key

# Groq (free: Whisper large-v3, 30 RPM)
GROQ_API_KEY=your_groq_key

# Supabase (free: 500MB DB, 1GB storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key

# Boxy Delivery API (Option B — 3PL aggregator)
BOXY_API_KEY=your_boxy_api_key
BOXY_API_SECRET=your_boxy_api_secret
# BOXY_API_URL=https://sandbox.tryboxy.com/v1  # uncomment for sandbox

# App
PORT=3000
